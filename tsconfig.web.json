{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "outDir": "dist/renderer",
    "types": ["vite/client"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/types/**/*.d.ts"
  ]
}
